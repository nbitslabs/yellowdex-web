---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLatestRelease } from "../lib/getLatestRelease";

const steps = [
  {
    title: "Spot an address",
    body: "Yellowdex floats beside any address you see on explorers, wallets, dashboards, and marketplaces.",
  },
  {
    title: "Label it in a tap",
    body: "Assign an entity, add a label and color-coded tags. Your labels appear everywhere you browse.",
  },
  {
    title: "Save to a collection",
    body: "Organize labels into collections (like a contact list) and share them with teammates or the public.",
  },
];

const features = [
  {
    title: "Works wherever you browse",
    body: "Detects addresses automatically on any page you visit—no special integrations needed. If a site shows an address, Yellowdex will find it.",
    chips: ["Etherscan", "Twitter", "Discord", "Docs"],
  },
  {
    title: "Smart search with filters",
    body: "Search with prefix syntax: a:0x123 for addresses, l:exchange for labels, e:uniswap for entities. Filter by current page or labeled status.",
    chips: ["a: address", "l: label", "e: entity", "Filters"],
  },
  {
    title: "Signal what matters",
    body: "Create custom color-coded tags to mark addresses however you choose. Pre-built risk categories coming soon.",
    chips: ["Custom tags", "Team", "DeFi", "OTC"],
  },
  {
    title: "Sync across devices",
    body: "Connect your wallet to sync labels across browsers, or keep everything local—your choice. Backups and exports always available.",
    chips: ["Wallet sync", "Local-first", "Privacy", "Export"],
  },
];

const faqs = [
  {
    q: "Is the Chrome link live?",
    a: "We’re finalizing the Chrome Web Store listing. For now the Install button uses a placeholder link—tap it to join the waitlist.",
  },
  {
    q: "Where do my labels live?",
    a: "Labels are local-first. You choose what to sync, what to export, and what to share with others.",
  },
  {
    q: "Which sites are supported?",
    a: "Any site that surfaces addresses. We prioritize major explorers, wallets, dashboards, and marketplaces.",
  },
  {
    q: "Can I collaborate with a team?",
    a: "Yes. Create a shared collection, generate a read-only link, and keep a single source of truth for labels.",
  },
  {
    q: "What about other browsers?",
    a: "Chrome first. Firefox and Edge are on the roadmap—join the list to be notified.",
  },
];

const latestRelease = await getLatestRelease();
---

<BaseLayout>
  <header class="sticky top-0 z-20 bg-paper/80 backdrop-blur">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 lg:px-8">
      <div class="flex items-center gap-3">
        <img src="/logo-yellowdex.svg" alt="Yellowdex logo" class="h-10 w-10" />
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-muted">Yellowdex</p>
          <p class="font-display text-lg text-ink">Label every address. Turn chaos into context.</p>
        </div>
      </div>
      <nav aria-label="Primary navigation" class="hidden items-center gap-6 text-sm font-medium text-ink-soft lg:flex">
        <a href="#features" class="transition hover:text-ink">Features</a>
        <a href="#release" class="transition hover:text-ink">Release notes</a>
        <a href="#how-it-works" class="transition hover:text-ink">How it works</a>
        <a href="#faq" class="transition hover:text-ink">FAQ</a>
        <a
          href="#"
          aria-label="Install Yellowdex on Chrome (placeholder link)"
          class="rounded-full bg-charcoal px-4 py-2 text-sm font-semibold text-sun shadow-lg shadow-amber/30 transition hover:-translate-y-0.5 hover:shadow-xl"
        >
          Install on Chrome
        </a>
      </nav>
    </div>
  </header>

  <main id="main" class="relative isolate">
    <section id="hero" class="px-6 pb-16 pt-12 sm:pt-16 lg:px-8 lg:pt-20">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
          <div class="space-y-6">
            <div class="inline-flex items-center gap-3 rounded-full bg-amber/15 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-amber">
              <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-amber text-charcoal">Y</span>
              Context for every crypto address
            </div>
            <h1 class="font-display text-4xl leading-tight text-charcoal sm:text-5xl lg:text-6xl">
              Label every address. Turn chaos into context.
            </h1>
            <p class="max-w-2xl text-lg text-muted">
              Yellowdex keeps context tethered to every address—on explorers, wallets, dashboards, marketplaces, and forums. Save
              labels to collections and share them with your team.
            </p>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
              <a
                href="#"
                aria-label="Install Yellowdex on Chrome (placeholder link)"
                class="inline-flex items-center justify-center gap-2 rounded-full bg-charcoal px-6 py-3 text-base font-semibold text-sun shadow-xl shadow-amber/30 transition hover:-translate-y-0.5 hover:shadow-2xl"
              >
                Install on Chrome
                <span aria-hidden="true">↗</span>
              </a>
              <a
                href="#how-it-works"
                class="inline-flex items-center justify-center gap-2 rounded-full border border-charcoal/10 bg-white/70 px-5 py-3 text-base font-semibold text-ink transition hover:-translate-y-0.5 hover:border-charcoal/20"
              >
                See how it works
              </a>
            </div>
            <div class="flex flex-wrap gap-4 text-sm text-muted">
              <div class="flex items-center gap-2 rounded-full bg-white/70 px-3 py-1 shadow-sm shadow-amber/10">
                <span class="h-2 w-2 rounded-full bg-emerald"></span>
                Local-first labels; you control sharing.
              </div>
              <div class="flex items-center gap-2 rounded-full bg-white/70 px-3 py-1 shadow-sm shadow-amber/10">
                <span class="h-2 w-2 rounded-full bg-amber"></span>
                Placeholder Chrome link until listing is live.
              </div>
            </div>
          </div>

          <div class="card relative overflow-hidden">
            <div class="relative space-y-4 p-8">
              <div id="overlay-badge" class="hidden w-fit rounded-full bg-amber/20 px-3 py-1 text-xs font-semibold text-amber">
                Live overlay preview
              </div>
              <!-- Default: no extension installed -->
              <div id="overlay-default" class="rounded-2xl border border-charcoal/10 bg-charcoal text-sun shadow-xl">
                <div class="flex items-center gap-3 px-4 py-3">
                  <div class="h-10 w-10 rounded-xl bg-sun/10 p-2">
                    <img src="/favicon.svg" alt="Yellowdex badge" class="h-full w-full" />
                  </div>
                  <p class="text-lg font-semibold text-white">Wormhole: 0xB0fF</p>
                </div>
                <div class="space-y-2 bg-black/30 px-4 py-3 text-sm text-sun/90">
                  <p><span class="text-amber">Entity:</span> Wormhole</p>
                  <div class="flex flex-wrap gap-2">
                    <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-white">Guardian (multisig)</span>
                    <span class="rounded-full bg-amber/20 px-3 py-1 text-xs font-semibold text-amber">Bridge</span>
                    <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-white">Team</span>
                    <span class="rounded-full bg-emerald/20 px-3 py-1 text-xs font-semibold text-emerald">Low risk</span>
                  </div>
                </div>
              </div>
              <!-- Shown when extension is installed -->
              <div id="overlay-extension" class="hidden rounded-2xl border border-charcoal/10 bg-charcoal text-sun shadow-xl">
                <div class="flex items-center gap-3 px-4 py-3">
                  <div class="h-10 w-10 rounded-xl bg-sun/10 p-2">
                    <img src="/favicon.svg" alt="Yellowdex badge" class="h-full w-full" />
                  </div>
                  <div>
                    <p class="text-xs uppercase tracking-wide text-amber">Address overlay</p>
                    <p class="text-lg font-semibold text-white">0xB0fFa8000886e57F86dd5264b9582b2Ad87b2b91</p>
                  </div>
                </div>
              </div>
              <p id="overlay-caption" class="text-xs text-ink/50">Install the extension and hover over the address to see Yellowdex in action.</p>

              <div class="grid gap-4 rounded-2xl border border-charcoal/10 bg-white/90 p-4 shadow-lg">
                <div class="flex items-center justify-between">
                  <p class="text-sm font-semibold text-ink">Collections</p>
                  <button aria-label="Share this collection" class="rounded-full bg-amber/20 px-3 py-1 text-xs font-semibold text-amber">Share</button>
                </div>
                <div class="grid grid-cols-2 gap-3 text-sm text-ink">
                  <div class="rounded-xl bg-amber/10 p-3 shadow-sm">
                    <p class="text-xs uppercase tracking-wide text-muted">DeFi collections</p>
                    <p class="text-base font-semibold text-charcoal">Major bridges</p>
                    <p class="text-xs text-muted">18 labels • shared</p>
                  </div>
                  <div class="rounded-xl bg-emerald/10 p-3 shadow-sm">
                    <p class="text-xs uppercase tracking-wide text-muted">Investigations</p>
                    <p class="text-base font-semibold text-charcoal">Exploiter watch</p>
                    <p class="text-xs text-muted">9 labels • private</p>
                  </div>
                  <div class="rounded-xl bg-white p-3 shadow-sm">
                    <p class="text-xs uppercase tracking-wide text-muted">OTC</p>
                    <p class="text-base font-semibold text-charcoal">Counterparties</p>
                    <p class="text-xs text-muted">24 labels</p>
                  </div>
                  <div class="rounded-xl bg-sun/10 p-3 shadow-sm">
                    <p class="text-xs uppercase tracking-wide text-muted">Personal</p>
                    <p class="text-base font-semibold text-charcoal">Friends & teams</p>
                    <p class="text-xs text-muted">12 labels</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 pb-16 lg:px-8" id="how-it-works">
      <div class="mx-auto max-w-6xl space-y-10">
        <div class="space-y-3">
          <p class="pill">How it works</p>
          <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
            <h2 class="font-display text-3xl text-charcoal sm:text-4xl">Dex-level context in three steps.</h2>
            <p class="max-w-2xl text-muted">
              Keep your address intel close to the surface. Yellowdex rides along anywhere you see an address and lets you capture,
              organize, and reuse that knowledge instantly.
            </p>
          </div>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {steps.map((step, idx) => (
            <div class="card relative h-full p-6">
              <div class="absolute -left-3 -top-3 flex h-10 w-10 items-center justify-center rounded-2xl bg-charcoal text-lg font-bold text-sun shadow-lg">
                {idx + 1}
              </div>
              <h3 class="mt-4 font-display text-xl text-charcoal">{step.title}</h3>
              <p class="mt-3 text-sm text-muted">{step.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 pb-16 lg:px-8" id="features">
      <div class="mx-auto max-w-6xl space-y-10">
        <div class="space-y-3">
          <p class="pill">What you get</p>
          <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
            <h2 class="font-display text-3xl text-charcoal sm:text-4xl">Built for power labelers.</h2>
            <p class="max-w-2xl text-muted">
              Structured, fast, and always on top of the page you are reading.
            </p>
          </div>
        </div>
        <div class="grid gap-6 md:grid-cols-2">
          {features.map((feature) => (
            <div class="card h-full p-6">
              <div class="flex items-center justify-between">
                <h3 class="font-display text-xl text-charcoal">{feature.title}</h3>
                <div class="h-2 w-10 rounded-full bg-amber"></div>
              </div>
              <p class="mt-3 text-sm text-muted">{feature.body}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {feature.chips.map((chip) => (
                  <span class="rounded-full bg-amber/15 px-3 py-1 text-xs font-semibold text-ink">{chip}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 pb-16 lg:px-8" id="collections">
      <div class="mx-auto max-w-6xl rounded-3xl border border-charcoal/10 bg-charcoal text-sun shadow-2xl shadow-amber/30">
        <div class="grid gap-8 p-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="space-y-4">
            <p class="pill inline-flex bg-white/10 text-white">Collections</p>
            <h2 class="font-display text-3xl leading-tight sm:text-4xl">Share a collection. Import with one click.</h2>
            <p class="text-base text-sun/90">
              Generate a share link for any collection and send it to your team. Recipients import the entire collection — entities,
              labels, and signals — with one click from the link.
            </p>
            <div class="grid gap-3 text-sm text-sun/90 sm:grid-cols-2">
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <p class="text-xs uppercase tracking-wide text-amber">Share links</p>
                <p class="mt-1 font-semibold text-white">Read-only shareable links</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <p class="text-xs uppercase tracking-wide text-amber">Exports</p>
                <p class="mt-1 font-semibold text-white">JSON export & import</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <p class="text-xs uppercase tracking-wide text-amber">Signals</p>
                <p class="mt-1 font-semibold text-white">Color-code risk, ownership, provenance</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <p class="text-xs uppercase tracking-wide text-amber">Access control</p>
                <p class="mt-1 font-semibold text-white">Private by default, granular sharing</p>
              </div>
            </div>
          </div>
          <!-- Share flow storyboard -->
          <div class="space-y-4">
            <!-- Panel 1: Share Modal -->
            <div class="card overflow-hidden bg-white/95 text-ink">
              <!-- Window chrome -->
              <div class="flex items-center gap-2 border-b border-charcoal/10 bg-charcoal/5 px-4 py-2.5">
                <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-amber"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-emerald"></span>
                <span class="ml-2 text-xs font-medium text-muted">Share Collection</span>
              </div>
              <!-- Modal body -->
              <div class="space-y-3 p-5">
                <div>
                  <p class="font-display text-lg font-bold text-charcoal">Bridge sentinels</p>
                  <p class="text-xs text-muted">4 entities &middot; 18 addresses</p>
                </div>
                <div>
                  <p class="text-[10px] font-semibold uppercase tracking-widest text-muted">Share Link</p>
                  <div class="mt-1 flex items-center gap-2">
                    <div class="flex-1 truncate rounded-lg border border-charcoal/10 bg-charcoal/5 px-3 py-2 font-mono text-xs text-charcoal">
                      sync.yellowdex.ai/s/a3x9k
                    </div>
                    <span class="shrink-0 rounded-lg bg-charcoal px-3 py-2 text-xs font-semibold text-sun">Copy</span>
                  </div>
                </div>
                <p class="text-xs text-muted">Anyone with this link can import your collection.</p>
              </div>
            </div>

            <!-- Arrow connector -->
            <div class="flex justify-center">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-amber text-charcoal">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v10.586l3.293-3.293a1 1 0 111.414 1.414l-5 5a1 1 0 01-1.414 0l-5-5a1 1 0 111.414-1.414L9 14.586V4a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
              </div>
            </div>

            <!-- Panel 2: Import Banner -->
            <div class="card overflow-hidden rounded-2xl border border-amber/30 bg-sun p-5 text-charcoal">
              <p class="font-display text-base font-bold">Collection Ready to Import</p>
              <p class="mt-1 text-xs text-charcoal/70">"Bridge sentinels" &middot; 4 entities &middot; 18 addresses</p>
              <p class="mt-2 text-[11px] text-charcoal/60">Click the Yellowdex extension icon to import.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 pb-16 lg:px-8" id="release">
      <div class="mx-auto max-w-6xl space-y-8">
        <div class="space-y-3">
          <p class="pill">Latest release</p>
          <h2 class="font-display text-3xl text-charcoal sm:text-4xl">Fresh from the Yellowdex extension.</h2>
          <p class="max-w-2xl text-muted">
            Release notes are pulled from the Yellowdex extension repo whenever a new version ships.
          </p>
        </div>

        {latestRelease ? (
          <div class="card flex flex-col gap-6 p-6 sm:flex-row sm:items-start sm:justify-between">
            <div class="space-y-3">
              <div class="flex flex-wrap items-center gap-3 text-sm text-muted">
                <span class="rounded-full bg-amber/15 px-3 py-1 text-xs font-semibold text-ink">{latestRelease.tagName}</span>
{latestRelease.publishedOn && <span>{latestRelease.publishedOn}</span>}
              </div>
              <h3 class="font-display text-2xl text-charcoal">{latestRelease.name}</h3>
              <div class="prose prose-sm max-w-none text-muted" set:html={latestRelease.bodyHtml} />
            </div>
          </div>
        ) : (
          <div class="card p-6">
            <h3 class="font-display text-xl text-charcoal">No release yet</h3>
            <p class="mt-2 text-muted">When the extension publishes a release, notes will appear here automatically.</p>
          </div>
        )}
      </div>
    </section>

    <section class="px-6 pb-16 lg:px-8" id="trust">
      <div class="mx-auto max-w-6xl rounded-3xl border border-charcoal/10 bg-white/90 p-8 shadow-xl">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
          <div class="space-y-3">
            <p class="pill">Trust & safety</p>
            <h2 class="font-display text-3xl text-charcoal sm:text-4xl">Built for teams who care about context.</h2>
            <p class="max-w-3xl text-muted">
              Privacy-first by design. Keep sensitive intel local, and publish only what’s meant to be shared. Export your data, back
              it up, and keep your notes portable.
            </p>
          </div>
          <div class="grid gap-3 text-sm text-ink sm:grid-cols-2">
            <div class="rounded-2xl bg-amber/10 p-4 shadow-sm">
              <p class="font-semibold text-charcoal">Local-first defaults</p>
              <p class="text-muted">No surprise syncs—opt in to sharing.</p>
            </div>
            <div class="rounded-2xl bg-emerald/10 p-4 shadow-sm">
              <p class="font-semibold text-charcoal">Backups & exports</p>
              <p class="text-muted">Export to JSON anytime.</p>
            </div>
            <div class="rounded-2xl bg-white p-4 shadow-sm">
              <p class="font-semibold text-charcoal">Team-friendly</p>
              <p class="text-muted">Share read-only links for collections.</p>
            </div>
            <div class="rounded-2xl bg-white p-4 shadow-sm">
              <p class="font-semibold text-charcoal">No dark patterns</p>
              <p class="text-muted">Clear controls, reversible choices.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 pb-16 lg:px-8" id="faq">
      <div class="mx-auto max-w-6xl space-y-8">
        <div class="space-y-3">
          <p class="pill">FAQ</p>
          <h2 class="font-display text-3xl text-charcoal sm:text-4xl">Answers at a glance.</h2>
          <p class="max-w-2xl text-muted">
            Questions about the extension, sharing, and supported surfaces. Want more? Drop us a note when you request access.
          </p>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          {faqs.map((item) => (
            <div class="card h-full p-5">
              <h3 class="font-semibold text-charcoal">{item.q}</h3>
              <p class="mt-2 text-sm text-muted">{item.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 pb-20 lg:px-8" id="install">
      <div class="mx-auto max-w-6xl overflow-hidden rounded-3xl border border-charcoal/10 bg-charcoal text-sun shadow-2xl shadow-amber/30">
        <div class="flex flex-col gap-6 px-8 py-10 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.2em] text-amber">Get Yellowdex</p>
            <h3 class="mt-2 font-display text-3xl text-white">Install on Chrome or join the list.</h3>
            <p class="mt-2 text-sun/90">Chrome link is a placeholder while the store listing is under review.</p>
          </div>
          <div class="flex flex-col gap-3 sm:flex-row">
            <a
              href="#"
              aria-label="Install Yellowdex on Chrome (placeholder link)"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-sun px-6 py-3 text-base font-semibold text-charcoal shadow-xl shadow-amber/40 transition hover:-translate-y-0.5 hover:shadow-2xl"
            >
              Install on Chrome
            </a>
            <a
              href="mailto:support@yellowdex.ai"
              aria-label="Request early access to Yellowdex"
              class="inline-flex items-center justify-center gap-2 rounded-full border border-white/20 px-5 py-3 text-base font-semibold text-white transition hover:-translate-y-0.5 hover:border-white/40"
            >
              Request early access
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-charcoal/10 bg-paper/80 px-6 py-10 lg:px-8">
    <div class="mx-auto flex max-w-6xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3">
        <img src="/logo-yellowdex.svg" alt="Yellowdex" class="h-10 w-10" />
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-muted">Yellowdex</p>
          <p class="text-sm text-ink-soft">Label every address. Turn chaos into context.</p>
        </div>
      </div>
      <div class="flex flex-wrap items-center gap-4 text-sm text-muted">
        <a href="#features" class="hover:text-ink">Features</a>
        <a href="#how-it-works" class="hover:text-ink">How it works</a>
        <a href="#faq" class="hover:text-ink">FAQ</a>
        <a href="mailto:support@yellowdex.ai" class="hover:text-ink">Contact</a>
        <a href="/privacy-policy/" class="hover:text-ink">Privacy Policy</a>
        <a href="https://x.com/yellowdex_ai" target="_blank" rel="noopener noreferrer" aria-label="Follow Yellowdex on X" class="hover:text-ink">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
      </div>
    </div>
  </footer>
<script>
  // Detect Yellowdex extension via its injected stylesheet
  function checkExtension() {
    if (document.getElementById('eth-labeler-fontawesome')) {
      document.getElementById('overlay-badge')?.classList.remove('hidden');
      document.getElementById('overlay-default')?.classList.add('hidden');
      document.getElementById('overlay-extension')?.classList.remove('hidden');
      document.getElementById('overlay-caption')?.classList.add('hidden');
    }
  }
  // Check after content scripts have loaded
  checkExtension();
  setTimeout(checkExtension, 500);
  setTimeout(checkExtension, 1500);
</script>
</BaseLayout>
