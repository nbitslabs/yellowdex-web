---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllReleases } from "../lib/getLatestRelease";

const releases = await getAllReleases();
---

<BaseLayout
  title="Release Notes - Yellowdex"
  description="See what's new in every Yellowdex extension release — features, fixes, and improvements."
>
  <header class="sticky top-0 z-20 bg-paper/80 backdrop-blur">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 lg:px-8">
      <div class="flex items-center gap-3">
        <a href="/" class="flex items-center gap-3">
          <img src="/logo-yellowdex.svg" alt="Yellowdex logo" class="h-10 w-10" />
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-muted">Yellowdex</p>
            <p class="font-display text-lg text-ink">Label every address. Turn chaos into context.</p>
          </div>
        </a>
      </div>
      <nav aria-label="Primary navigation" class="hidden items-center gap-6 text-sm font-medium text-ink-soft lg:flex">
        <a href="/#features" class="transition hover:text-ink">Features</a>
        <a href="/releases/" class="transition hover:text-ink">Release notes</a>
        <a href="/#how-it-works" class="transition hover:text-ink">How it works</a>
        <a href="/#faq" class="transition hover:text-ink">FAQ</a>
        <a
          href="https://chromewebstore.google.com/detail/lapdeiobkgdfjfcdddjbmmhooicppmha"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Install Yellowdex on Chrome"
          class="rounded-full bg-charcoal px-4 py-2 text-sm font-semibold text-sun shadow-lg shadow-amber/30 transition hover:-translate-y-0.5 hover:shadow-xl"
        >
          Install on Chrome
        </a>
      </nav>
    </div>
  </header>

  <main id="main" class="px-6 py-12 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <a href="/" class="inline-flex items-center gap-2 text-sm font-medium text-muted transition hover:text-ink">
        <span aria-hidden="true">&larr;</span> Back to Yellowdex
      </a>

      <div class="mt-8 space-y-3">
        <p class="pill">Release notes</p>
        <h1 class="font-display text-4xl font-semibold text-charcoal">What's new in Yellowdex</h1>
        <p class="text-muted">
          Every update to the Yellowdex Chrome extension, pulled straight from GitHub releases.
        </p>
      </div>

      {releases.length > 0 ? (
        <div class="mt-10 space-y-8">
          {releases.map((release) => (
            <article class="card p-6">
              <div class="flex flex-wrap items-center gap-3 text-sm text-muted">
                <span class="rounded-full bg-amber/15 px-3 py-1 text-xs font-semibold text-ink">{release.tagName}</span>
                {release.publishedOn && <span>{release.publishedOn}</span>}
              </div>
              <h2 class="mt-3 font-display text-2xl text-charcoal">{release.name}</h2>
              <div class="prose prose-sm mt-4 max-w-none text-muted" set:html={release.bodyHtml} />
            </article>
          ))}
        </div>
      ) : (
        <div class="card mt-10 p-6">
          <h2 class="font-display text-xl text-charcoal">No releases yet</h2>
          <p class="mt-2 text-muted">When the extension publishes releases, notes will appear here automatically.</p>
        </div>
      )}
    </div>
  </main>

  <footer class="border-t border-charcoal/10 bg-paper/80 px-6 py-10 lg:px-8">
    <div class="mx-auto flex max-w-6xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3">
        <img src="/logo-yellowdex.svg" alt="Yellowdex" class="h-10 w-10" />
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-muted">Yellowdex</p>
          <p class="text-sm text-ink-soft">Label every address. Turn chaos into context.</p>
        </div>
      </div>
      <div class="flex flex-wrap items-center gap-4 text-sm text-muted">
        <a href="/#features" class="hover:text-ink">Features</a>
        <a href="/#how-it-works" class="hover:text-ink">How it works</a>
        <a href="/#faq" class="hover:text-ink">FAQ</a>
        <a href="mailto:support@yellowdex.ai" class="hover:text-ink">Contact</a>
        <a href="/privacy-policy/" class="hover:text-ink">Privacy Policy</a>
        <a href="https://x.com/yellowdex_ai" target="_blank" rel="noopener noreferrer" aria-label="Follow Yellowdex on X" class="hover:text-ink">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
      </div>
    </div>
  </footer>
</BaseLayout>
